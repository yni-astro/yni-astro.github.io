source "https://rubygems.org"

# Jekyll itself. We pin to ~> 4.3 (latest 4.x as of writing) for modern features.
# When you eventually publish via GitHub Pages, the GitHub Actions workflow we
# document in PUBLISH.md will use this same version, so what you see locally
# matches what the world sees.
gem "jekyll", "~> 4.3"

# Markdown processor — supports footnotes, tables, code blocks, math, etc.
gem "kramdown-parser-gfm"

# webrick is required by `jekyll serve` on Ruby 3+
gem "webrick", "~> 1.8"
